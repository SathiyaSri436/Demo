<Window x:Class="demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:demo"
        mc:Ignorable="d"
        Title="Demo" Height="450" Width="800">
    <StackPanel>
        <Button Content="File Create" Name="btncreate" Click="btncreate_Click" BorderBrush="Red" BorderThickness="1"></Button>
        <Border></Border>
        <Button Content="File Write" Name="btnwrite" Click="btnwrite_Click" BorderBrush="Red" BorderThickness="1"></Button>
        <Button Content="File Delete" Name="btndelete" Click="btndelete_Click" BorderBrush="Red" BorderThickness="1"></Button>
        <Button Content="File Read" Name="btnread" Click="btnread_Click" BorderBrush="Red" BorderThickness="1"></Button>

        <StackPanel>
            <Button Content="Folder Create" Name="btnfoldercreate" Click="btnfoldercreate_Click" BorderBrush="Red" BorderThickness="1"></Button>
            <Border></Border>
            <Button Content="Folder Exists" Name="btnfolderexists"  BorderBrush="Red" BorderThickness="1"></Button>
            <Button Content="Folder Delete" Name="btnfolderdelete" Click="btnfolderdelete_Click" BorderBrush="Red" BorderThickness="1"></Button>
            <Button Content="Get Files" Name="btngetfile" Click="btngetfile_Click" BorderBrush="Red" BorderThickness="1"></Button>
        </StackPanel>
    </StackPanel>
</Window>
